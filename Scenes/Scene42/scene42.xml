      <joint name="object_2_joint" type="hinge" axis="0 1 0"/>
    </body>
    <!-- Fixed Support -->
    <body name="object_3" pos="0 0 2">
      <geom type="sphere" size="0.2" rgba="0.5 0.5 0.5 1"/>
    </body>
  </worldbody>
