    <!-- Sliding Cube (Purple, frictionless) -->
    <body name="object_2" pos="5 0 1">
      <geom type="box" size="0.5 0.5 0.5" density="1" rgba="0.7 0.1 0.7 1" friction="0 0 0"/>
