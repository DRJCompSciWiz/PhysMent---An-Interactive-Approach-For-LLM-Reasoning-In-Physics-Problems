<mujoco>
  <!-- Task guidance: Work from the Sliding vs Rolling Down a Curve scene state rather than from the title alone. Query accessible object parameters and, when the task involves motion, collisions, forces, or oscillation, step the simulator and compare measured states before submitting the numeric answer. -->
  <option gravity="0 0 -9.81"/>
  <worldbody>
    <!-- Rolling Sphere (Cyan) -->
    <body name="object_1" pos="-5 0 1">
      <geom type="sphere" size="0.4" density="1" rgba="0.1 0.7 0.7 1"/>
      <joint name="object_1_joint" type="free"/>
