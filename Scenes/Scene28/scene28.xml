<mujoco>
  <!-- Task guidance: Work from the Spring-Mass Oscillator scene state rather than from the title alone. Query accessible object parameters and, when the task involves motion, collisions, forces, or oscillation, step the simulator and compare measured states before submitting the numeric answer. -->
  <option gravity="0 0 -9.81"/>
  <worldbody>
    <!-- Support (fixed wall for spring attachment) -->
    <body name="object_3" pos="0 0 1">
      <geom type="box" size="0.2 0.2 0.2" rgba="0.6 0.6 0.6 1"/>
      <site name="support_site" pos="-0.2 0 0" size="0.01"/>
    </body>
    <!-- Ground Surface -->
    <body name="object_4" pos="-10 0 -0.1">
      <geom type="plane" size="25 25 0.1" rgba="0.8 0.8 0.8 1" friction="0.1 0.1 0.1"/>
    </body>
    <!-- Mass (Green Box, 1 kg) -->
    <body name="object_1" pos="-3 0 1">
      <geom type="box" size="0.3 0.3 0.3" mass="1" rgba="0.2 0.8 0.2 1"/>
      <joint name="object_1_joint" type="free"/>
      <site name="mass_site" pos="0.3 0 0" size="0.01"/>
    </body>
    <!-- Spring (visual capsule) -->
    <body name="object_2" pos="0 0 1">
      <geom type="capsule" fromto="0 0 0 -3 0 0" size="0.05" rgba="0.8 0.8 0.2 1"/>
    </body>
  </worldbody>

  <!-- Spring tendon connecting mass to support -->
  <tendon>
    <spatial limited="true" range="0 5" stiffness="50" width="0.02">
      <site site="mass_site"/>
      <site site="support_site"/>
    </spatial>
  </tendon>
</mujoco>
