<mujoco>
  <!-- Task guidance: Work from the Energy Conservation on a Swing scene state rather than from the title alone. Query accessible object parameters and, when the task involves motion, collisions, forces, or oscillation, step the simulator and compare measured states before submitting the numeric answer. -->
  <option gravity="0 0 -9.81"/>
  <worldbody>
    <!-- Pendulum -->
    <body name="object_1" pos="-5 0 2">
      <geom type="capsule" fromto="0 0 0 0 0 -1.5" size="0.05" rgba="0.1 0.8 0.8 1"/>
      <joint name="object_1_joint" type="hinge" axis="0 1 0"/>
    </body>
    <!-- Sliding Block -->
    <body name="object_2" pos="5 0 1">
      <geom type="box" size="0.5 0.5 0.5" density="1" rgba="0.8 0.4 0.2 1" friction="0 0 0"/>
      <joint name="object_2_joint" type="free"/>
    </body>
    <!-- Frictionless Ramp -->
    <body name="object_3" pos="0 0 0">
      <geom type="plane" size="5 10 0.1" rgba="0.6 0.6 0.6 1" friction="0 0 0" quat="0.5 0.86 0 0"/>
    </body>
    <!-- Ground Surface -->
    <body name="object_4" pos="-10 0 -10">
      <geom type="plane" size="30 30 0.1" rgba="0.8 0.8 0.8 1" friction="1 1 1"/>
    </body>
  </worldbody>
</mujoco>
