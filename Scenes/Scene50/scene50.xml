<mujoco>
  <!-- Task guidance: Perturb both spring-mounted blocks in comparable ways and measure their oscillation periods over the same kind of time window. Use the measured slower/faster cycle timing to identify the heavier block and period ratio. -->
  <option gravity="0 0 -9.81" />
  <worldbody>
    <light diffuse="0.5 0.5 0.5" pos="0 0 5" dir="0 0 -1" />
    <body name="object_5" pos="0 0 -10">
      <geom type="plane" size="50 50 0.1" rgba="0.9 0.9 0.9 1" />
    </body>
    <body name="object_3" pos="-2 0 3">
      <geom type="capsule" fromto="0 0 0 0 0 -1" size="0.02" rgba="0.8 0.8 0.2 1" />
      <site name="object_3_site" pos="0 0 -1" size="0.01" />
    </body>
    <body name="object_4" pos="2 0 3">
      <geom type="capsule" fromto="0 0 0 0 0 -1" size="0.02" rgba="0.8 0.8 0.2 1" />
      <site name="object_4_site" pos="0 0 -1" size="0.01" />
    </body>
    <body name="object_1" pos="-2 0 2">
      <geom type="box" size="0.3 0.3 0.3" mass="2" rgba="0.6 0.2 1 1" />
      <joint type="slide" axis="0 0 1" limited="true" range="0 5" name="object_1_joint" />
      <site name="object_1_site" pos="0 0 0" size="0.01" />
    </body>
    <body name="object_2" pos="2 0 2">
      <geom type="box" size="0.3 0.3 0.3" mass="4" rgba="0.1 0.7 0.7 1" />
      <joint type="slide" axis="0 0 1" limited="true" range="0 5" name="object_2_joint" />
      <site name="object_2_site" pos="0 0 0" size="0.01" />
    </body>
  </worldbody>
  <tendon>
    <spatial name="spring1" width="0.01" stiffness="50">
      <site site="object_3_site" />
      <site site="object_1_site" />
    </spatial>
    <spatial name="spring2" width="0.01" stiffness="50">
      <site site="object_4_site" />
      <site site="object_2_site" />
    </spatial>
  </tendon>
</mujoco>
