<?xml version="1.0" encoding="UTF-8"?>
<mujoco model="rolling_cylinder_vs_sliding_block">
  <!-- Task guidance: Work from the Rolling Cylinder vs Sliding Block scene state rather than from the title alone. Query accessible object parameters and, when the task involves motion, collisions, forces, or oscillation, step the simulator and compare measured states before submitting the numeric answer. -->
    <compiler angle="radian"/>
    <option gravity="0 0 -9.81"/>

    <worldbody>
        <!-- Inclined Plane (Static) -->
        <body name="object_1" pos="0 0 0">
            <geom name="ramp" type="plane" size="10 10 0.1" rgba="0.8 0.8 0.8 1"
                  euler="-0.35 0 0" friction="1 0.005 0.0001" condim="4"/>
        </body>

        <!-- Cylinder (Dynamic, Rolling) -->
        <body name="object_2" pos="-0.3 0 2">
            <joint name="object_2_joint" type="free"/>
            <geom name="cylinder_geom" type="cylinder" size="0.1 0.3" mass="1"
                    rgba="1 0 0 1" friction="0.8 0.005 0.0001" condim="4"/>
        </body>

        <!-- Block (Dynamic, Sliding) -->
        <body name="object_3" pos="0.3 0 2">
            <joint name="object_3_joint" type="free"/>
            <geom name="block_geom" type="box" size="0.1 0.1 0.1" mass="1"
                    rgba="0 0 1 1" friction="0.1 0.005 0.0001" condim="4"/>
        </body>
    </worldbody>

    <actuator>
        <!-- No actuators needed; gravity and friction handle motion -->
    </actuator>
</mujoco>
