<mujoco model="atwood_machine">
  <!-- Task guidance: Work from the Atwood Machine scene state rather than from the title alone. Query accessible object parameters and, when the task involves motion, collisions, forces, or oscillation, step the simulator and compare measured states before submitting the numeric answer. -->
  <compiler angle="radian" />
  <option timestep="0.01" />
  <default>
    <joint armature="0" damping="0.1" stiffness="0" />
    <geom condim="3" friction="0.5 0.1 0.1" />
  </default>
  <worldbody>
    <body name="object_1" pos="0 0 1.5">
      <geom type="cylinder" size="0.05 0.1" rgba="0.5 0.5 0.5 1" />
    </body>
    <body name="object_2" pos="0 0 1.5">
      <geom type="capsule" fromto="-0.2 0 0 0.2 0 0" size="0.01" rgba="0.8 0.8 0.2 1" />
    </body>
    <body name="object_3" pos="-0.2 0 1">
      <joint name="object_3_joint" type="slide" axis="0 0 1" />
      <geom type="sphere" size="0.05" mass="0.5" rgba="0 0 1 1" />
      <site name="object_3_site" pos="0 0 0" />
    </body>
    <body name="object_4" pos="0.2 0 1.2">
      <joint name="object_4_joint" type="slide" axis="0 0 1" />
      <geom type="sphere" size="0.05" mass="1.0" rgba="1 0 0 1" />
      <site name="object_4_site" pos="0 0 0" />
    </body>
    <site name="pulley_site" pos="0 0 1.5" />
  </worldbody>
  <tendon>
    <spatial>
      <site site="object_3_site" />
      <site site="pulley_site" />
      <site site="object_4_site" />
    </spatial>
  </tendon>
</mujoco>
